{
  "manifest_version": 3,
  "name": "Ориентир — Защита от ИИ-слежки",
  "version": "0.1.0",
  "description": "Внешний фильтр между вами и ИИ. Блокирует телеметрию, поведенческие данные и слежку на ChatGPT, Claude, Gemini. Реализация Уровня 7 архитектуры защиты «Ориентир».",
  "author": "Ориентир",
  "homepage_url": "https://orenpro.pro/pages/orientir.html",

  "icons": {
    "16": "icons/icon-16.png",
    "32": "icons/icon-32.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  },

  "action": {
    "default_popup": "popup/popup.html",
    "default_icon": {
      "16": "icons/icon-16.png",
      "32": "icons/icon-32.png",
      "48": "icons/icon-48.png"
    },
    "default_title": "Ориентир — Защита активна"
  },

  "background": {
    "service_worker": "background.js",
    "type": "module"
  },

  "content_scripts": [
    {
      "matches": [
        "https://chatgpt.com/*",
        "https://chat.openai.com/*",
        "https://claude.ai/*",
        "https://gemini.google.com/*",
        "https://aistudio.google.com/*",
        "https://www.perplexity.ai/*",
        "https://you.com/*",
        "https://poe.com/*",
        "https://character.ai/*",
        "https://replika.com/*"
      ],
      "js": ["content.js"],
      "run_at": "document_start",
      "all_frames": false,
      "world": "MAIN"
    }
  ],

  "permissions": [
    "storage",
    "declarativeNetRequest",
    "webRequest",
    "tabs",
    "activeTab",
    "scripting"
  ],

  "host_permissions": [
    "https://chatgpt.com/*",
    "https://chat.openai.com/*",
    "https://claude.ai/*",
    "https://gemini.google.com/*",
    "https://aistudio.google.com/*",
    "https://www.perplexity.ai/*",
    "https://you.com/*",
    "https://poe.com/*",
    "https://character.ai/*",
    "https://replika.com/*"
  ],

  "declarative_net_request": {
    "rule_resources": [
      {
        "id": "telemetry_rules",
        "enabled": true,
        "path": "rules/telemetry_rules.json"
      }
    ]
  },

  "options_ui": {
    "page": "options/options.html",
    "open_in_tab": true
  },

  "web_accessible_resources": [
    {
      "resources": ["popup/popup.html", "options/options.html"],
      "matches": ["<all_urls>"]
    }
  ]
}
